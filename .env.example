# MLS Oracle v4.1 — Environment Variables

# Discord webhook for alerts (required for Discord embeds)
DISCORD_WEBHOOK_URL=

# The Odds API for live Vegas lines (optional — free tier: 500 requests/month)
# Get your key at https://the-odds-api.com
ODDS_API_KEY=

# Cache and database paths (optional — defaults shown)
CACHE_DIR=./cache
DB_PATH=./data/mls_oracle.db
CACHE_TTL_HOURS=6

# Log level: trace | debug | info | warn | error
LOG_LEVEL=info
